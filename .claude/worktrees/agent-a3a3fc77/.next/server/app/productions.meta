{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/productions/layout,_N_T_/productions/page,_N_T_/productions"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/productions/__PAGE__",
    "/productions",
    "/_index",
    "/_head"
  ]
}